{
	"name": "kargo",
	"version": "0.1.3",
	"description": "Kargo is a keyboard-first minimal desktop web browser built with Electron.",
	"main": "src/main.js",
	"scripts": {
		"start": "electron .",
		"dev": "electron . --enable-logging --watch",
		"build": "electron-builder",
		"build:win": "electron-builder --win",
		"build:mac": "electron-builder --mac",
		"build:linux": "electron-builder --linux"
	},
	"keywords": [
		"electron",
		"browser",
		"minimal",
		"keyboard",
		"webview"
	],
	"author": "aardaakpinar",
	"repository": {
		"type": "git",
		"url": "https://github.com/aardaakpinar/kargo"
	},
	"license": "MIT",
	"devDependencies": {
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1"
	},
	"build": {
		"asar": true,
		"appId": "com.kargo.browser",
		"productName": "Kargo",
		"directories": {
			"output": "dist"
		},
		"files": [
			"src/**/*",
			"package.json"
		],
		"mac": {
			"icon": "src/static/icon.icns",
			"category": "public.app-category.productivity"
		},
		"win": {
			"icon": "src/static/icon.ico",
			"target": "nsis"
		},
		"linux": {
			"icon": "src/static/icon.png",
			"target": "AppImage"
		}
	}
}
